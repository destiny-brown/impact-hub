generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id                String             @id @default(cuid())
  title             String
  slug              String             @unique
  description       String?
  location          String
  date              DateTime
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  capacity          Int
  volunteerRequests VolunteerRequest[]
}

model Volunteer {
  id        String             @id @default(cuid())
  fullName  String
  email     String             @unique
  phone     String?
  location  String?
  bio       String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  requests  VolunteerRequest[]
}

model VolunteerRequest {
  id                 String        @id @default(cuid())
  volunteerId        String
  message            String?
  status             RequestStatus @default(PENDING)
  requestedStartDate DateTime?
  requestedEndDate   DateTime?
  approvedAt         DateTime?
  approvedBy         String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  eventId            String
  event              Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  volunteer          Volunteer     @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  @@index([volunteerId])
  @@index([eventId])
  @@index([status])
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}
