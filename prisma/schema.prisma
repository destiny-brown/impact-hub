generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

model Charity {
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  description       String?
  websiteUrl        String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  volunteerRequests VolunteerRequest[]
}

model Volunteer {
  id        String             @id @default(cuid())
  fullName  String
  email     String             @unique
  phone     String?
  location  String?
  bio       String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  requests  VolunteerRequest[]
}

model VolunteerRequest {
  id                 String        @id @default(cuid())
  volunteerId        String
  charityId          String
  message            String?
  status             RequestStatus @default(PENDING)
  requestedStartDate DateTime?
  requestedEndDate   DateTime?
  approvedAt         DateTime?
  approvedBy         String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  volunteer          Volunteer     @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  charity            Charity       @relation(fields: [charityId], references: [id], onDelete: Cascade)

  @@index([volunteerId])
  @@index([charityId])
  @@index([status])
}
